# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=8080
APP_ENV=development          # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost             # Em Docker use o nome do serviço: postgres
DB_PORT=5432
DB_USER=controltasks
DB_PASSWORD=controltasks      # Troque em produção
DB_NAME=controltasks
DB_SSLMODE=disable            # Em produção considere: require

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por vírgula das origens permitidas
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 48
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria-em-producao

# Deve ter EXATAMENTE 32 caracteres (AES-256)
# Gere com: openssl rand -base64 24 | cut -c1-32
FIELD_ENCRYPT_KEY=troque-por-32-chars-exatos-aqui!!
